---
import Contact from "../components/contact.astro";
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
const gallery = await getCollection("gallery");
---

<Layout title="Gallery">
  <main class="dark min-h-screen pt-32 pb-16 px-6 md:px-12">
    
    <header class="text-center mb-20">
      <h1 class="text-white font-ztotez text-4xl md:text-5xl tracking-[0.2em] uppercase mb-4">
        Gallery
      </h1>
      <p class="text-[#d9c5b2]/60 font-colitezserif text-sm">Select a memory to explore</p>
    </header>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-6 max-w-7xl mx-auto category-grid">
      {
        gallery.map((category) => (
          <a 
            href={`/gallery/${encodeURI(category.data.title)}`} 
            class="category-card group relative aspect-square overflow-hidden  border border-[#d9c5b2]/10 shadow-xl opacity-0 translate-y-4"
          >
            <img 
              src={category.data.images[0]} 
              alt={category.data.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
            />

            <div class="absolute inset-0 bg-black/30 group-hover:bg-black/50 transition-colors duration-500"></div>

            <div class="absolute inset-0 flex flex-col justify-center items-center p-4 text-center">
              <h2 class="text-lg md:text-xl font-colitezserif tracking-widest uppercase transition-transform duration-500 group-hover:-translate-y-2">
                {category.data.title}
              </h2>
              
              <span class="w-0 h-px  transition-all duration-500 group-hover:w-12 mt-2"></span>
              
              <p class="text-[#d9c5b2]/0 text-[10px] uppercase tracking-[0.2em] mt-4 transition-all duration-500 ">
                View Gallery
              </p>
            </div>
          </a>
        ))
      }
    </div>

  </main>
  <Contact />
</Layout>

<script>
  import { gsap } from "gsap";

  // Simple staggered entrance for the categories
  window.addEventListener('DOMContentLoaded', () => {
    gsap.to(".category-card", {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.2,
      ease: "power3.out"
    });
  });
</script>