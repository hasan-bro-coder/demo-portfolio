---
import { getCollection } from "astro:content";
const gallery = await getCollection("gallery");
const featured = gallery.filter((item) => item.data.featured);

---

<section
  id="gallery"
  class="w-screen min-h-[250vh] pb-32 light flex flex-col items-center gap-8"
>
  <h1 class="text-6xl my-8 mt-32">Gallery</h1>
  <!-- <div class="grid grid-cols-2 md:grid-cols-3 gap-3 w-[80vw] max-w-6xl"> -->
  <div class="columns-2 md:columns-3 lg:columns-4 gap-4 w-[80vw] max-w-6xl">
    {
      featured[0].data.images.map((img: any) => (
        <img src={img} />
      ))
    }
  </div>
</section>

<style>
  #gallery {
    background-color: rgb(206, 206, 206);
  }
  img {
    width: 100%;
    /* height: 100%; */
    /* aspect-ratio: 1/1; */
    /* object-fit: cover; */
    border-radius: 5px;
    margin-top: 8px;
  }
</style>
