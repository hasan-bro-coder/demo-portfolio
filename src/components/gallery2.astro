---
import { getCollection } from "astro:content";
// import {collections} from  "../content/config"
const gallery = await getCollection("gallery");
const featured = gallery.filter((item) => item.data.featured);

---

<section
  id="gallery"
  class="w-screen min-h-[250vh] h-full light flex flex-col items-center gap-8"
>
  <h1 class="text-6xl my-8 mt-32">Gallery</h1>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 w-[80vw] max-w-6xl">
    {
      featured[0].data.images.map((img: any) => (
        <img src={img} />
      ))
    }
    <!-- <div id="gallery-con" class="columns-2 md:columns-3 gap-3 w-[80vw] max-w-6xl"> -->
    <!-- <div id="gallery-con" class="grid gap-3 w-[80vw] max-w-6xl"> -->
    <!-- <div class="flex flex-col gap-3"> -->
    <img src="prop.jpg" alt="image" />
    <img src="pfp.jpg" alt="image" />
    <img src="prop.jpg" alt="image" />
    <img src="prop.jpg" alt="image" />
    <img src="pfp.jpg" alt="image" />
    <img src="prop.jpg" alt="image" />
    <!-- </div> -->
    <img src="hero.jpg" alt="image" />
    <img src="pfp.jpg" alt="image" />
    <img src="hero.jpg" alt="image" />
    <img src="pfp.jpg" alt="image" />
    <img src="hero.jpg" alt="image" />
    <img src="pfp.jpg" alt="image" />
    <img src="hero.jpg" alt="image" />
    <!-- <div class="flex flex-col gap-3"> -->
    <img src="pfp.jpg" alt="image" />
    <img src="prop.jpg" alt="image" />
    <img src="prop.jpg" alt="image" />
    <img src="pfp.jpg" alt="image" />
    <img src="prop.jpg" alt="image" />
    <img src="pfp.jpg" alt="image" />
    <!-- </div> -->
    <!-- <div class="flex flex-col gap-3"> -->
    <!-- </div> -->
  </div>
</section>
<style>
  #gallery {
    background-color: rgb(206, 206, 206);
  }
  img {
    width: 100%;
    height: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    border-radius: 5px;
  }
  #gallery-con {
    grid-template-columns: repeat(3, 64px);
    grid-row: 64px;
  }
</style>
