<section id="about" class="absolute top-[100vh] dark w-screen h-[120vh] flex justify-center items-center">
    <div id="about-container" class="flex w-[80%] h-[80%] gap-8">
        <img class="about-image" src="pfp.jpg"></img>
        <div class="flex flex-col gap-2">
            <h1 class="text-3xl font-bold">About Me</h1>
            <h2 class="works text-xl">photographer</h2>
            <p class="mt-2">Lorem ipsum dolor sit amet, consectetur adipisicing elit. Deserunt fugiat fuga harum eligendi veniam suscipit tenetur explicabo a atque aperiam ad ullam modi necessitatibus aut, optio quod, </p>
        </div>
    </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);
  gsap.to("#about", {
    scrollTrigger: {
      start: "top top",
      trigger: "#about",
      scrub: true,
    },
    y: 300,
  });
</script>

<style>
    #about-container{
        display: grid;
        grid-template-columns: 1fr 2fr;
        grid-template-rows: 1fr;
        place-items: center;
    }
    nav {
        z-index: 100;
    }
    svg {
        fill: white;
        width: 32px;
        height: 32px;
    }
</style>